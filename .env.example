# Copy to .env and fill in real values.

# Payload secret used to sign auth tokens. Generate with: openssl rand -hex 32
PAYLOAD_SECRET=

# Postgres connection string (Neon recommended).
# Neon example: postgres://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/DB?sslmode=require
DATABASE_URL=

# Vercel Blob read/write token for media uploads in production.
# Create in Vercel dashboard > Storage > Blob. Leave blank locally to use disk.
BLOB_READ_WRITE_TOKEN=

# Canonical public URL of the site (no trailing slash). Used for CORS/CSRF, SEO, and sitemap.
NEXT_PUBLIC_SERVER_URL=https://www.launch-nest.com

# Google Analytics 4 measurement ID (optional override; defaults to G-1TVY097ZKY in site config).
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-1TVY097ZKY

# Optional: forward qualified leads to an external CRM webhook as well.
CRM_WEBHOOK_URL=

# Lead notification emails (via Resend). Get a key at https://resend.com
# Leave RESEND_API_KEY blank to disable emails (Payload logs them to console).
RESEND_API_KEY=
# Address notifications are sent TO (your inbox).
LEAD_NOTIFICATION_EMAIL=
# Address notifications are sent FROM. Must be on a Resend-verified domain,
# or use onboarding@resend.dev for testing (only delivers to your own email).
EMAIL_FROM=onboarding@resend.dev

# Optional: auto-screenshot provider for the Projects collection.
# Leave blank to use the free, keyless provider (thum.io).
# For higher quality + ad/cookie-banner blocking, add a ScreenshotOne key:
#   https://screenshotone.com  ->  Dashboard  ->  Access key
SCREENSHOTONE_ACCESS_KEY=
# Force the free provider even when a key is set (values: thumio)
SCREENSHOT_PROVIDER=
